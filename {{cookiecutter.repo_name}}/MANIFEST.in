graft docs
graft src
graft ci
graft tests

{% if cookiecutter.version_manager == 'bump2version' -%}
include .bumpversion.cfg
{% endif -%}
include .cookiecutterrc
include .coveragerc
include .editorconfig
{% if cookiecutter.github_actions -%}
include .github/workflows/github-actions.yml
{% endif -%}
{% if cookiecutter.pre_commit -%}
include .pre-commit-config.yaml
{% endif -%}
{% if cookiecutter.sphinx_docs and 'readthedocs' in cookiecutter.sphinx_docs_hosting -%}
include .readthedocs.yml
{% endif -%}
include .tombi.toml
include pyproject.toml
include pytest.ini
{% if cookiecutter.version_manager == 'tbump' -%}
include tbump.toml
{% endif -%}
include tox.ini

include AUTHORS.rst
include CHANGELOG.rst
include CONTRIBUTING.rst
include LICENSE
include README.rst

global-exclude *.py[cod] __pycache__/* *.so *.dylib
